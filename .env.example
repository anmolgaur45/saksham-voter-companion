# Backend — copy to apps/backend/.env.local
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-south1
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-2.5-flash
VERTEX_SEARCH_DATASTORE_ID=your-datastore-id
FIRESTORE_DATABASE=saksham-voter-companion
LOG_LEVEL=INFO
INTERNAL_API_KEY=            # shared secret used with the API-key auth escape hatch

# Web — copy to apps/web/.env.local
BACKEND_URL=http://localhost:8000
GCP_PROJECT_ID=your-gcp-project-id
NEXT_PUBLIC_MAPS_API_KEY=    # restrict by HTTP referrer after first deploy
INTERNAL_API_KEY=            # must match the backend value if using the escape hatch
